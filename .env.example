# ─────────────────────────────────────────────────────────────────────────────
# JV With Niche — environment template
# Copy to .env.local and fill in. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Public site URL — used in OG tags, return-link construction, redirects.
NEXT_PUBLIC_SITE_URL="https://jvwithniche.com"

# ── Database (Postgres) ─────────────────────────────────────────────────────
# Vercel Postgres / Neon / Supabase — full connection string.
DATABASE_URL="postgres://user:pass@host:5432/jvwithniche"

# ── File storage ────────────────────────────────────────────────────────────
# Vercel Blob token (https://vercel.com/docs/storage/vercel-blob).
BLOB_READ_WRITE_TOKEN=""

# ── E-signature: PandaDoc (primary) ─────────────────────────────────────────
PANDADOC_API_KEY=""                     # Sandbox or production API key. Find via `npm run pandadoc:ping`.
PANDADOC_TEMPLATE_ID=""                 # UUID of the JV agreement template (see ping output).
PANDADOC_WEBHOOK_SHARED_KEY=""          # Shared secret set when creating the webhook in PandaDoc.
NICHE_SIGNER_NAME="Michael Franke"      # Niche-side signer displayed in the PandaDoc recipient list.
NICHE_SIGNER_EMAIL="michael@nichesolutions.ai"

# ── E-signature: Jotform Sign (fallback) ────────────────────────────────────
JOTFORM_API_KEY=""
JOTFORM_SIGN_FORM_ID=""
JOTFORM_WEBHOOK_SHARED_KEY=""

# Which provider this deployment uses: "pandadoc" | "jotform"
ESIGN_PROVIDER="pandadoc"

# ── Niche CRM webhook (Salesforce middleware — provided by CRM team) ────────
CRM_WEBHOOK_URL=""
CRM_WEBHOOK_AUTH_HEADER="X-API-Key"
CRM_WEBHOOK_AUTH_VALUE=""

# ── WhatsApp provider (Whapi.Cloud or AiSensy — pick one at deploy time) ────
WHATSAPP_PROVIDER="whapi"                  # "whapi" | "aisensy"
WHATSAPP_API_KEY=""
WHATSAPP_API_BASE_URL=""

# Fixed Niche team members (E.164) — added to every JV WhatsApp group.
NICHE_WHATSAPP_TEAM_1=""
NICHE_WHATSAPP_TEAM_2=""
NICHE_WHATSAPP_TEAM_3=""
NICHE_WHATSAPP_TEAM_4=""

# WhatsApp number (E.164) that receives the operator notification when a
# submission is signed (group name + members + welcome + view link + PDF).
# Defaults to WHAPI_BOUND_PHONE_E164 (the bot's own number, visible in
# WhatsApp's "Message yourself" chat on the paired device).
WHAPI_NOTIFY_PHONE_E164=""

# ── Calendly (kickoff call booking) ─────────────────────────────────────────
# Closer's Calendly scheduling URL. We append prefill params (name, email,
# property) to this base URL and surface it on the post-sign screen, the
# /view/<token> portal, and inside the WhatsApp messages.
CALENDLY_BOOKING_URL=""
# Calendly Personal Access Token. Currently unused by the basic prefill
# flow (URL params only), reserved for future webhooks / single-use links.
CALENDLY_API_TOKEN=""

# ── Spam protection ─────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
RECAPTCHA_MIN_SCORE="0.5"

# ── Google Places Autocomplete ──────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=""

# ── Transactional email (dev alerts only — NOT submitter notifications) ─────
EMAIL_PROVIDER="resend"                    # "resend" | "sendgrid"
RESEND_API_KEY=""
SENDGRID_API_KEY=""
# DEV_ALERT_FROM defaults to "Niche JV Alerts <onboarding@resend.dev>".
# Resend's free tier only lets that from-address send to the Resend
# account owner's verified email, so DEV_ALERT_TO must match that owner
# until a domain (e.g. jvwithniche.com) is verified in the Resend
# dashboard. Once verified, set DEV_ALERT_FROM="Niche JV Alerts
# <alerts@jvwithniche.com>" and DEV_ALERT_TO can be anyone (e.g. Michael).
DEV_ALERT_FROM=""
DEV_ALERT_TO=""

# ── Admin auth (seed the first admin user) ──────────────────────────────────
ADMIN_SEED_EMAIL=""
ADMIN_SEED_PASSWORD=""
ADMIN_SESSION_SECRET=""                    # 32+ char random string for signing cookies

# ── Cron security ───────────────────────────────────────────────────────────
CRON_SECRET=""                             # Shared secret sent as Bearer by Vercel Cron
