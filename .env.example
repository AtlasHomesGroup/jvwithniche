# ─────────────────────────────────────────────────────────────────────────────
# JV With Niche — environment template
# Copy to .env.local and fill in. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Public site URL — used in OG tags, return-link construction, redirects.
NEXT_PUBLIC_SITE_URL="https://jvwithniche.com"

# ── Database (Postgres) ─────────────────────────────────────────────────────
# Vercel Postgres / Neon / Supabase — full connection string.
DATABASE_URL="postgres://user:pass@host:5432/jvwithniche"

# ── File storage ────────────────────────────────────────────────────────────
# Vercel Blob token (https://vercel.com/docs/storage/vercel-blob).
BLOB_READ_WRITE_TOKEN=""

# ── E-signature: PandaDoc (primary) ─────────────────────────────────────────
PANDADOC_API_KEY=""
PANDADOC_TEMPLATE_ID=""
PANDADOC_WEBHOOK_SHARED_KEY=""

# ── E-signature: Jotform Sign (fallback) ────────────────────────────────────
JOTFORM_API_KEY=""
JOTFORM_SIGN_FORM_ID=""
JOTFORM_WEBHOOK_SHARED_KEY=""

# Which provider this deployment uses: "pandadoc" | "jotform"
ESIGN_PROVIDER="pandadoc"

# ── Niche CRM webhook (Salesforce middleware — provided by CRM team) ────────
CRM_WEBHOOK_URL=""
CRM_WEBHOOK_AUTH_HEADER="X-API-Key"
CRM_WEBHOOK_AUTH_VALUE=""

# ── WhatsApp provider (Whapi.Cloud or AiSensy — pick one at deploy time) ────
WHATSAPP_PROVIDER="whapi"                  # "whapi" | "aisensy"
WHATSAPP_API_KEY=""
WHATSAPP_API_BASE_URL=""

# Fixed Niche team members (E.164) — added to every JV WhatsApp group.
NICHE_WHATSAPP_TEAM_1=""
NICHE_WHATSAPP_TEAM_2=""
NICHE_WHATSAPP_TEAM_3=""
NICHE_WHATSAPP_TEAM_4=""

# ── Spam protection ─────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
RECAPTCHA_MIN_SCORE="0.5"

# ── Google Places Autocomplete ──────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=""

# ── Transactional email (dev alerts only — NOT submitter notifications) ─────
EMAIL_PROVIDER="resend"                    # "resend" | "sendgrid"
RESEND_API_KEY=""
SENDGRID_API_KEY=""
DEV_ALERT_FROM="alerts@jvwithniche.com"
DEV_ALERT_TO="michael@nichedata.ai"

# ── Admin auth (seed the first admin user) ──────────────────────────────────
ADMIN_SEED_EMAIL=""
ADMIN_SEED_PASSWORD=""
ADMIN_SESSION_SECRET=""                    # 32+ char random string for signing cookies

# ── Cron security ───────────────────────────────────────────────────────────
CRON_SECRET=""                             # Shared secret sent as Bearer by Vercel Cron
